# Backend Environment Variables

# Server Configuration
PORT=3005
NODE_ENV=development

# Frontend URL — used to build verification/password-reset email links AND as a
# CORS origin. MUST point at the live frontend or those email links 404.
# Local development: http://localhost:3000
# Production: https://playsluff.com   (NOT the old sluff.netlify.app, which is dead)
CLIENT_ORIGIN=http://localhost:3000

# Database
POSTGRES_CONNECT_STRING="your_postgres_connection_string_here"

# Authentication
JWT_SECRET=your_jwt_secret_here

# AI Integration
AI_SECRET_KEY=your_ai_secret_key_here

# Admin
ADMIN_SECRET=your_admin_secret_here

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDER_EMAIL_ADDRESS=noreply@yourdomain.com
# Resend (current email provider)
RESEND_API_KEY=
